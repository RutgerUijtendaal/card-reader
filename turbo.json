{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "scripts/build-sidecars.mjs",
    "services/core/src/**",
    "services/api/src/**",
    "services/parser/src/**",
    "services/*/pyproject.toml",
    "services/*/uv.lock"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "src-tauri/target/**", "src-tauri/binaries/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "fix": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "format": {
      "outputs": []
    }
  }
}
