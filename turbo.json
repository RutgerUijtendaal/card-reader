{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "services/core/src/**",
    "services/api/src/**",
    "services/parser/src/**",
    "services/*/pyproject.toml"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "fix": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "format": {
      "outputs": []
    }
  }
}
