# Runtime mode
CARD_READER_ENV=production

# API bind target on the host machine (for docker-compose port publishing)
CARD_READER_API_BIND=127.0.0.1

# Shared storage root inside containers
CARD_READER_APP_DATA_DIR=/var/lib/card-reader
CARD_READER_DATABASE_PATH=card_reader.db

# Disable crop dumps in production by default
CARD_READER_SAVE_DEBUG_CROPS=false

# Set your frontend origin(s) as JSON array
# Example: ["https://cards.example.com","https://admin.example.com"]
CARD_READER_CORS_ORIGINS=["http://localhost:5173"]

# Skip Paddle model host connectivity check
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
