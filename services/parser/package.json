{
  "name": "@card-reader/parser",
  "version": "0.1.10",
  "private": true,
  "scripts": {
    "predev": "uv sync --project ../.. --all-packages --all-groups --locked",
    "dev": "uv run --project ../.. --package card-reader-parser python -m card_reader_parser.main",
    "build": "echo \"Python service has no build step\"",
