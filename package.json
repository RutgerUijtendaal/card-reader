{
  "name": "card-reader",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "deps:js": "pnpm install",
    "deps:py": "uv sync --project . --all-packages --all-groups --locked",
    "setup": "pnpm deps:js && pnpm deps:py",
    "sync:python": "pnpm deps:py",
    "version:repo": "uv run --no-project python scripts/set-version.py",
    "version:check": "uv run --no-project python scripts/check-version.py",
    "dev": "turbo run dev --parallel --filter=!@card-reader/desktop",
    "dev:all": "turbo run dev --parallel",
    "dev:desktop": "pnpm --filter @card-reader/desktop dev",
    "build": "turbo run build",
    "build:desktop": "pnpm --filter @card-reader/desktop run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck && turbo run lint && turbo run test",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
